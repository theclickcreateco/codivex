# Codivex Agency Environment Variables

# Recipient email address for contact form submissions
CONTACT_EMAIL=codivexagency@gmail.com

# Resend API key (get one from https://resend.com)
# Update this with your live key (e.g. re_xxxxxxxxx)
RESEND_API_KEY=re_your_api_key_here

# Verified domain sender address in Resend (defaults to Resend testing domain if onboarding)
RESEND_FROM_EMAIL=onboarding@resend.dev
