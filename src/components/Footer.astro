---
// Footer Component
---

<footer class="bg-surface-container-lowest border-t border-outline-ghost/30 text-on-surface py-16 md:py-20 relative overflow-hidden">
  
  <!-- Subtle dark glow backdrop -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[80%] h-[300px] bg-primary-maroon/5 blur-[150px] pointer-events-none rounded-full"></div>

  <div class="max-w-[1280px] mx-auto px-4 md:px-8 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16">
      
      <!-- Column 1: Shopify Suite -->
      <div>
        <h3 class="text-sm font-semibold tracking-[0.1em] text-white uppercase mb-6 flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-primary-accent rounded-full"></span>
          Shopify Suite
        </h3>
        <ul class="space-y-4">
          <li>
            <a href="/services/shopify-development" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Shopify Theme Dev
            </a>
          </li>
          <li>
            <a href="/services/headless-commerce" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Hydrogen / Headless
            </a>
          </li>
          <li>
            <a href="/services/shopify-development#optimization" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Checkout Extensibility
            </a>
          </li>
          <li>
            <a href="/services/shopify-development#audits" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              App & Speed Audits
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 2: WordPress Ecosystem -->
      <div>
        <h3 class="text-sm font-semibold tracking-[0.1em] text-white uppercase mb-6 flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-primary-accent rounded-full"></span>
          WordPress Hubs
        </h3>
        <ul class="space-y-4">
          <li>
            <a href="/services/wordpress-block-themes" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              FSE Block Themes
            </a>
          </li>
          <li>
            <a href="/services/wordpress-block-themes#gutenberg" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Gutenberg Custom Blocks
            </a>
          </li>
          <li>
            <a href="/services/wordpress-block-themes#woocommerce" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              WooCommerce Hubs
            </a>
          </li>
          <li>
            <a href="/services/wordpress-block-themes#migration" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              WordPress Headless
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Custom JavaScript -->
      <div>
        <h3 class="text-sm font-semibold tracking-[0.1em] text-white uppercase mb-6 flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-primary-accent rounded-full"></span>
          Custom JS
        </h3>
        <ul class="space-y-4">
          <li>
            <a href="/services/nextjs-astro-web-apps" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Next.js Applications
            </a>
          </li>
          <li>
            <a href="/services/nextjs-astro-web-apps" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Astro Content Engines
            </a>
          </li>
          <li>
            <a href="/services/headless-commerce" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Decoupled Architectures
            </a>
          </li>
          <li>
            <a href="/services/nextjs-astro-web-apps#edge" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Edge-Optimized Systems
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Wix Studio Solutions -->
      <div>
        <h3 class="text-sm font-semibold tracking-[0.1em] text-white uppercase mb-6 flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-primary-accent rounded-full"></span>
          Wix Studio
        </h3>
        <ul class="space-y-4">
          <li>
            <a href="/services/wix-studio-design" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Wix Studio Design
            </a>
          </li>
          <li>
            <a href="/services/wix-studio-design#animations" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Velo API Scripting
            </a>
          </li>
          <li>
            <a href="/services/wix-studio-design#headless" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Wix Headless APIs
            </a>
          </li>
          <li>
            <a href="/services/wix-studio-design#migration" class="text-sm text-secondary-silver hover:text-primary-accent transition-colors">
              Figma-to-Wix Buildouts
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Divider Line -->
    <div class="h-[1px] bg-outline-ghost/30 w-full mb-12"></div>

    <!-- Bottom Footer Metadata -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      
      <!-- Brand Details -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <div class="flex items-center gap-3">
          <div class="w-7 h-7 flex items-center justify-center bg-gradient-to-br from-primary-maroon to-primary-maroon-dark border border-primary-accent/30 rounded-default overflow-hidden">
            <img src="/android-chrome-192x192.png" alt="Codivex logo" class="w-full h-full object-contain" />
          </div>
          <span class="text-white font-bold text-base tracking-[0.1em]">CODIVEX</span>
        </div>
        <p class="text-xs text-on-surface-variant/70 text-center md:text-left">
          Strategy-led digital experiences for founders, growth teams, and established brands.
        </p>
      </div>

      <!-- Developer Partner Badging -->
      <div class="flex flex-wrap justify-center gap-4 text-xs font-semibold text-secondary-silver/80">
        <div class="px-3 py-1.5 border border-outline-ghost/40 bg-surface-container-low rounded-full flex items-center gap-1.5 shadow-sm">
          <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
          Shopify Dev Partner
        </div>
        <div class="px-3 py-1.5 border border-outline-ghost/40 bg-surface-container-low rounded-full flex items-center gap-1.5 shadow-sm">
          <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>
          Wix Studio Partner
        </div>
        <div class="px-3 py-1.5 border border-outline-ghost/40 bg-surface-container-low rounded-full flex items-center gap-1.5 shadow-sm">
          <span class="w-1.5 h-1.5 bg-primary-accent rounded-full"></span>
          WordPress Core Contributor
        </div>
        <div class="px-3 py-1.5 border border-outline-ghost/40 bg-surface-container-low rounded-full flex items-center gap-1.5 shadow-sm">
          <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
          Vercel Verified
        </div>
      </div>

    </div>

    <div class="mt-12 text-center md:flex md:justify-between md:items-center">
      <p class="text-xs text-on-surface-variant/50">
        &copy; {new Date().getFullYear()} Codivex Ltd. All rights reserved. Built for ambitious brands at every stage.
      </p>
      <div class="flex justify-center gap-6 mt-4 md:mt-0 text-xs text-on-surface-variant/60">
        <a href="#" class="hover:text-primary-accent">Privacy Policy</a>
        <a href="#" class="hover:text-primary-accent">Terms of Service</a>
        <a href="#" class="hover:text-primary-accent">Security Info</a>
      </div>
    </div>

  </div>
</footer>
