---
// Header Component
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-outline-ghost/30 glass-panel" id="main-header">
  <div class="max-w-[1280px] mx-auto px-4 md:px-8 h-20 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group focus:outline-none" aria-label="Codivex Home">
      <div class="relative w-9 h-9 flex items-center justify-center bg-gradient-to-br from-primary-maroon to-primary-maroon-dark border border-primary-accent/30 rounded-default overflow-hidden">
        <img src="/android-chrome-192x192.png" alt="Codivex logo" class="w-full h-full object-contain" />
      </div>
      <span class="text-on-surface font-bold text-xl tracking-[0.08em] transition-colors group-hover:text-primary-accent">
        CODIVEX
      </span>
    </a>

    <!-- Navigation Menu (Desktop) -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Global Navigation">
      
      <!-- Dropdown: E-Commerce Engine -->
      <div class="relative group dropdown-container">
        <button 
          class="flex items-center gap-1.5 py-2 text-sm font-medium text-secondary-silver hover:text-primary-accent transition-colors cursor-pointer focus:outline-none" 
          aria-expanded="false" 
          aria-haspopup="true"
        >
          E-Commerce Engine
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180 dropdown-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute left-0 mt-2 w-64 rounded-md border border-outline-ghost/40 bg-surface-container-high p-2 shadow-2xl opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 focus-within:opacity-100 focus-within:translate-y-0 focus-within:pointer-events-auto">
          <a 
            href="/services/shopify-development" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">Shopify Ecosystem</span>
            <span class="text-xs text-on-surface-variant/80">Liquid, Hydrogen, Custom Apps</span>
          </a>
          <a 
            href="/services/headless-commerce" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">Custom Headless Commerce</span>
            <span class="text-xs text-on-surface-variant/80">Astro/Next.js paired with Shopify</span>
          </a>
          <a 
            href="/services/wordpress-block-themes" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">WooCommerce Hubs</span>
            <span class="text-xs text-on-surface-variant/80">WordPress commerce integrations</span>
          </a>
        </div>
      </div>

      <!-- Dropdown: Content & Marketing Hubs -->
      <div class="relative group dropdown-container">
        <button 
          class="flex items-center gap-1.5 py-2 text-sm font-medium text-secondary-silver hover:text-primary-accent transition-colors cursor-pointer focus:outline-none" 
          aria-expanded="false" 
          aria-haspopup="true"
        >
          Content & Marketing Hubs
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180 dropdown-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute left-0 mt-2 w-64 rounded-md border border-outline-ghost/40 bg-surface-container-high p-2 shadow-2xl opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 focus-within:opacity-100 focus-within:translate-y-0 focus-within:pointer-events-auto">
          <a 
            href="/services/wordpress-block-themes" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">WordPress Block Themes</span>
            <span class="text-xs text-on-surface-variant/80">Full Site Editing & Custom Blocks</span>
          </a>
          <a 
            href="/services/nextjs-astro-web-apps" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">Astro Static Sites</span>
            <span class="text-xs text-on-surface-variant/80">Sub-second performance engineering</span>
          </a>
          <a 
            href="/services/wix-studio-design" 
            class="flex flex-col gap-0.5 rounded-default p-3 hover:bg-surface-container-highest transition-colors group/item"
          >
            <span class="text-sm font-semibold text-white group-hover/item:text-primary-accent">Wix Studio</span>
            <span class="text-xs text-on-surface-variant/80">Interactive visuals & zero maintenance</span>
          </a>
        </div>
      </div>

      <!-- Links: Our Work -->
      <a href="/#case-studies" class="text-sm font-medium text-secondary-silver hover:text-primary-accent transition-colors">
        Our Work / Case Studies
      </a>
    </nav>

    <!-- Right Side CTAs -->
    <div class="hidden lg:flex items-center gap-6">
      <a 
        href="/#contact" 
        class="relative inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-secondary-silver bg-primary-maroon border border-primary-accent/40 rounded-default glow-btn-primary cursor-pointer hover:text-white"
        style="box-shadow: inset 0 1px 0 rgba(255, 179, 181, 0.2);"
      >
        Start Your Project
      </a>
    </div>

    <!-- Burger Menu (Mobile) -->
    <button 
      class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-default border border-outline-ghost/30 hover:bg-surface-container-low transition-colors focus:outline-none"
      id="mobile-menu-toggle"
      aria-label="Toggle Navigation Menu"
      aria-expanded="false"
    >
      <span class="w-5 h-0.5 bg-secondary-silver transition-all duration-300 mobile-bar"></span>
      <span class="w-5 h-0.5 bg-secondary-silver transition-all duration-300 mobile-bar"></span>
      <span class="w-5 h-0.5 bg-secondary-silver transition-all duration-300 mobile-bar"></span>
    </button>

  </div>

  <!-- Mobile Drawer Menu -->
  <div 
    class="lg:hidden fixed top-20 left-0 w-full h-[calc(100vh-5rem)] bg-surface/98 backdrop-blur-md border-t border-outline-ghost/20 z-40 transform translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
    id="mobile-drawer"
  >
    <div class="px-6 py-8 flex flex-col gap-8">
      
      <!-- E-Commerce Engine Dropdown (Mobile Accordion) -->
      <div class="flex flex-col gap-2">
        <button 
          class="flex items-center justify-between text-lg font-bold text-white text-left focus:outline-none"
          id="mobile-accordion-1"
        >
          E-Commerce Engine
          <svg class="w-5 h-5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="hidden flex-col pl-4 gap-3 border-l border-outline-ghost/20 mt-2" id="mobile-panel-1">
          <a href="/services/shopify-development" class="py-1 text-base text-secondary-silver hover:text-primary-accent">Shopify Ecosystem</a>
          <a href="/services/headless-commerce" class="py-1 text-base text-secondary-silver hover:text-primary-accent">Custom Headless Commerce</a>
          <a href="/services/wordpress-block-themes" class="py-1 text-base text-secondary-silver hover:text-primary-accent">WooCommerce Hubs</a>
        </div>
      </div>

      <!-- Content & Marketing Dropdown (Mobile Accordion) -->
      <div class="flex flex-col gap-2">
        <button 
          class="flex items-center justify-between text-lg font-bold text-white text-left focus:outline-none"
          id="mobile-accordion-2"
        >
          Content & Marketing Hubs
          <svg class="w-5 h-5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="hidden flex-col pl-4 gap-3 border-l border-outline-ghost/20 mt-2" id="mobile-panel-2">
          <a href="/services/wordpress-block-themes" class="py-1 text-base text-secondary-silver hover:text-primary-accent">WordPress Block Themes</a>
          <a href="/services/nextjs-astro-web-apps" class="py-1 text-base text-secondary-silver hover:text-primary-accent">Astro Static Sites</a>
          <a href="/services/wix-studio-design" class="py-1 text-base text-secondary-silver hover:text-primary-accent">Wix Studio</a>
        </div>
      </div>

      <!-- Case Studies Link -->
      <a href="/#case-studies" class="text-lg font-bold text-white hover:text-primary-accent transition-colors" id="mobile-link-cases">
        Our Work / Case Studies
      </a>

      <!-- Start Your Project CTA -->
      <a 
        href="/#contact" 
        class="w-full text-center py-3.5 text-base font-semibold text-secondary-silver bg-primary-maroon border border-primary-accent/40 rounded-default glow-btn-primary inline-block hover:text-white"
        id="mobile-link-contact"
      >
        Start Your Project
      </a>
      
    </div>
  </div>

</header>

<script>
  // Sticky nav border adjustment on scroll
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('shadow-xl', 'bg-surface/90');
      header?.classList.remove('bg-surface/75');
    } else {
      header?.classList.remove('shadow-xl', 'bg-surface/90');
      header?.classList.add('bg-surface/75');
    }
  });

  // Mobile Menu Drawer Toggling
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const bars = document.querySelectorAll('.mobile-bar');

  if (menuToggle && mobileDrawer) {
    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isExpanded));
      
      if (!isExpanded) {
        // Open
        mobileDrawer.classList.remove('translate-x-full');
        bars[0].classList.add('rotate-45', 'translate-y-2');
        bars[1].classList.add('opacity-0');
        bars[2].classList.add('-rotate-45', '-translate-y-2');
        document.body.style.overflow = 'hidden'; // Lock body scroll
      } else {
        // Close
        mobileDrawer.classList.add('translate-x-full');
        bars[0].classList.remove('rotate-45', 'translate-y-2');
        bars[1].classList.remove('opacity-0');
        bars[2].classList.remove('-rotate-45', '-translate-y-2');
        document.body.style.overflow = '';
      }
    });

    // Close mobile drawer on clicking anchor links
    const mobileLinks = ['mobile-link-cases', 'mobile-link-contact'];
    mobileLinks.forEach(id => {
      document.getElementById(id)?.addEventListener('click', () => {
        mobileDrawer.classList.add('translate-x-full');
        bars[0].classList.remove('rotate-45', 'translate-y-2');
        bars[1].classList.remove('opacity-0');
        bars[2].classList.remove('-rotate-45', '-translate-y-2');
        menuToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }

  // Mobile Dropdown Accordions
  const setupAccordion = (btnId, panelId) => {
    const btn = document.getElementById(btnId);
    const panel = document.getElementById(panelId);
    
    if (btn && panel) {
      btn.addEventListener('click', () => {
        const arrow = btn.querySelector('svg');
        const isHidden = panel.classList.contains('hidden');
        
        if (isHidden) {
          panel.classList.remove('hidden');
          panel.classList.add('flex');
          arrow?.classList.add('rotate-180');
        } else {
          panel.classList.remove('flex');
          panel.classList.add('hidden');
          arrow?.classList.remove('rotate-180');
        }
      });
    }
  };

  setupAccordion('mobile-accordion-1', 'mobile-panel-1');
  setupAccordion('mobile-accordion-2', 'mobile-panel-2');

  // Accessible Keyboard Dropdowns for Desktop
  const dropdownContainers = document.querySelectorAll('.dropdown-container');
  dropdownContainers.forEach(container => {
    const btn = container.querySelector('button');
    const links = container.querySelectorAll('a');
    
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
      });
      
      // Close when clicking outside
      window.addEventListener('click', () => {
        btn.setAttribute('aria-expanded', 'false');
      });

      // Escape key to close
      container.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') {
          btn.setAttribute('aria-expanded', 'false');
          btn.focus();
        }
      });
    }
  });
</script>
