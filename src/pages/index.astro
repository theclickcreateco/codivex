---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="No platform bias. Just results. We build premium, high-performance websites across Shopify, Wix Studio, WordPress, and Custom React/Astro applications.">
  
  <!-- 1. HERO SECTION -->
  <section class="relative pt-36 pb-24 md:pt-48 md:pb-32 overflow-hidden bg-surface">
    <!-- Geometric decorative lights (backlight) -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary-maroon/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/10 w-[600px] h-[400px] bg-primary-maroon/5 rounded-full blur-[150px] pointer-events-none"></div>
    
    <!-- Ghost grids -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(193,199,207,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(193,199,207,0.03)_1px,transparent_1px)] bg-[size:4rem_4rem] pointer-events-none"></div>

    <div class="max-w-[1280px] mx-auto px-4 md:px-8 relative z-10 text-center">
      
      <!-- Premium Tag -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-primary-accent/20 bg-primary-maroon/10 text-xs font-semibold text-primary-accent tracking-[0.1em] uppercase mb-8 animate-fade-in">
        <span class="w-1.5 h-1.5 bg-primary-accent rounded-full animate-ping"></span>
        Digital Architecture Studio
      </div>

      <!-- Headline H1 -->
      <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-[-0.02em] leading-[1.1] max-w-[950px] mx-auto mb-6">
        We Build High-Performance <span class="bg-gradient-to-r from-secondary-silver via-white to-primary-accent bg-clip-text text-transparent">Digital Experiences.</span> No Tech Bias. Just Results.
      </h1>

      <!-- Subheadline -->
      <p class="text-base md:text-xl text-secondary-silver max-w-[800px] mx-auto leading-relaxed mb-12">
        From seamless visual websites built on Wix Studio and WordPress to custom-engineered platforms using Shopify, Next.js, and Astro. We align the perfect tech stack with your business scale.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a 
          href="#contact" 
          class="w-full sm:w-auto px-8 py-4 text-base font-bold text-white bg-primary-maroon border border-primary-accent/40 rounded-default glow-btn-primary hover:text-white transition-all shadow-lg text-center"
          style="box-shadow: inset 0 1px 0 rgba(255, 179, 181, 0.2);"
        >
          Book a Tech Strategy Call
        </a>
        <a 
          href="#pillars" 
          class="w-full sm:w-auto px-8 py-4 text-base font-bold text-secondary-silver bg-surface-container-low border border-outline-ghost rounded-default hover:bg-surface-container hover:text-white transition-all text-center"
        >
          Explore Our Stacks
        </a>
      </div>

    </div>
  </section>

  <!-- 3. SOCIAL PROOF & AUTHORITY SECTION -->
  <section class="py-12 bg-surface-container-lowest border-y border-outline-ghost/30 overflow-hidden relative">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8 mb-4">
      <p class="text-center text-xs font-bold uppercase tracking-[0.2em] text-on-surface-variant/60">
        Trusted Engineering & Official Deployments
      </p>
    </div>

    <!-- Scrolling Marquee Container -->
    <div class="flex relative w-full overflow-hidden select-none">
      <!-- Shadow Overlays for fade effect -->
      <div class="absolute top-0 left-0 h-full w-20 md:w-40 bg-gradient-to-r from-surface-container-lowest to-transparent z-10 pointer-events-none"></div>
      <div class="absolute top-0 right-0 h-full w-20 md:w-40 bg-gradient-to-l from-surface-container-lowest to-transparent z-10 pointer-events-none"></div>

      <!-- Marquee track -->
      <div class="flex gap-16 whitespace-nowrap animate-marquee py-4">
        
        <!-- Group 1 -->
        <div class="flex items-center gap-12 text-sm font-semibold text-secondary-silver">
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span> Official Shopify Developer
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-500 rounded-full"></span> Wix Studio Partner
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-primary-accent rounded-full"></span> WordPress Core Contributor
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-white rounded-full"></span> Vercel Verified
          </span>
          <span class="text-white/20 tracking-wider">APEX BRAND</span>
          <span class="text-white/20 tracking-wider">ZENITH CORP</span>
          <span class="text-white/20 tracking-wider">VELO LABS</span>
          <span class="text-white/20 tracking-wider">ACME GROUP</span>
        </div>

        <!-- Group 2 (Duplicate for Infinite Loop) -->
        <div class="flex items-center gap-12 text-sm font-semibold text-secondary-silver">
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span> Official Shopify Developer
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-500 rounded-full"></span> Wix Studio Partner
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-primary-accent rounded-full"></span> WordPress Core Contributor
          </span>
          <span class="flex items-center gap-2">
            <span class="w-2 h-2 bg-white rounded-full"></span> Vercel Verified
          </span>
          <span class="text-white/20 tracking-wider">APEX BRAND</span>
          <span class="text-white/20 tracking-wider">ZENITH CORP</span>
          <span class="text-white/20 tracking-wider">VELO LABS</span>
          <span class="text-white/20 tracking-wider">ACME GROUP</span>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. THE CROSSROAD: FIND YOUR STACK -->
  <section class="py-24 md:py-32 bg-surface relative" id="pillars">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70%] h-[500px] bg-primary-maroon/5 blur-[150px] pointer-events-none rounded-full"></div>

    <div class="max-w-[1280px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- Section Header -->
      <div class="text-center mb-16 max-w-[800px] mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-6">
          The Right Foundation for Every Digital Strategy
        </h2>
        <p class="text-base md:text-lg text-secondary-silver">
          We engineer websites based on your operational model, budget, and long-term scaling goals.
        </p>
      </div>

      <!-- 4 Pillars Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Pillar 1: Wix Studio -->
        <div class="group relative flex flex-col justify-between p-8 bg-surface-container-low border border-outline-ghost rounded-lg glow-card h-full">
          <div>
            <div class="flex items-center justify-between mb-8">
              <span class="text-xs font-bold tracking-widest text-primary-accent uppercase">01 / Visual Engine</span>
              <span class="px-2 py-0.5 text-[10px] font-bold bg-blue-500/10 border border-blue-500/30 text-blue-400 rounded-full">Agile</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-primary-accent transition-colors">Wix Studio</h3>
            <p class="text-sm font-semibold text-secondary-silver/70 uppercase tracking-wide mb-4">The Visual Accelerator</p>
            <p class="text-sm text-on-surface-variant/90 mb-6 leading-relaxed">
              <strong>Best For:</strong> Service businesses, startups, and agile brands needing rapid deployment, stunning interactive animations, and a secure backend without maintenance overhead.
            </p>
            <div class="border-t border-outline-ghost/30 pt-4 mb-8">
              <p class="text-xs font-semibold text-secondary-silver mb-2">Core Tech:</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Wix Studio Engine</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Velo APIs</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Wix Headless</span>
              </div>
            </div>
          </div>
          <a href="/services/wix-studio-design" class="text-sm font-bold text-primary-accent group-hover:text-white transition-colors inline-flex items-center gap-1.5 focus:outline-none">
            Explore Wix Studio Services <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

        <!-- Pillar 2: WordPress -->
        <div class="group relative flex flex-col justify-between p-8 bg-surface-container-low border border-outline-ghost rounded-lg glow-card h-full">
          <div>
            <div class="flex items-center justify-between mb-8">
              <span class="text-xs font-bold tracking-widest text-primary-accent uppercase">02 / Content</span>
              <span class="px-2 py-0.5 text-[10px] font-bold bg-primary-accent/10 border border-primary-accent/30 text-primary-accent rounded-full">Control</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-primary-accent transition-colors">WordPress</h3>
            <p class="text-sm font-semibold text-secondary-silver/70 uppercase tracking-wide mb-4">The Content Powerhouse</p>
            <p class="text-sm text-on-surface-variant/90 mb-6 leading-relaxed">
              <strong>Best For:</strong> Media publishers, corporate marketing setups, and brands looking for complete, open-source content control via a native, localized environment.
            </p>
            <div class="border-t border-outline-ghost/30 pt-4 mb-8">
              <p class="text-xs font-semibold text-secondary-silver mb-2">Core Tech:</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Full Site Editing (FSE)</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Gutenberg Blocks</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">WooCommerce</span>
              </div>
            </div>
          </div>
          <a href="/services/wordpress-block-themes" class="text-sm font-bold text-primary-accent group-hover:text-white transition-colors inline-flex items-center gap-1.5 focus:outline-none">
            Explore WordPress Services <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

        <!-- Pillar 3: Shopify -->
        <div class="group relative flex flex-col justify-between p-8 bg-surface-container-low border border-outline-ghost rounded-lg glow-card h-full">
          <div>
            <div class="flex items-center justify-between mb-8">
              <span class="text-xs font-bold tracking-widest text-primary-accent uppercase">03 / Commerce</span>
              <span class="px-2 py-0.5 text-[10px] font-bold bg-green-500/10 border border-green-500/30 text-green-400 rounded-full">DTC / B2B</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-primary-accent transition-colors">Shopify</h3>
            <p class="text-sm font-semibold text-secondary-silver/70 uppercase tracking-wide mb-4">The Commerce Standard</p>
            <p class="text-sm text-on-surface-variant/90 mb-6 leading-relaxed">
              <strong>Best For:</strong> High-volume retail brands, direct-to-consumer storefronts, and multi-currency global operations focused on seamless logistics and checkout.
            </p>
            <div class="border-t border-outline-ghost/30 pt-4 mb-8">
              <p class="text-xs font-semibold text-secondary-silver mb-2">Core Tech:</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Liquid Themes</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Checkout Extensibility</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Hydrogen Headless</span>
              </div>
            </div>
          </div>
          <a href="/services/shopify-development" class="text-sm font-bold text-primary-accent group-hover:text-white transition-colors inline-flex items-center gap-1.5 focus:outline-none">
            Explore Shopify Services <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

        <!-- Pillar 4: Custom JS -->
        <div class="group relative flex flex-col justify-between p-8 bg-surface-container-low border border-outline-ghost rounded-lg glow-card h-full">
          <div>
            <div class="flex items-center justify-between mb-8">
              <span class="text-xs font-bold tracking-widest text-primary-accent uppercase">04 / Performance</span>
              <span class="px-2 py-0.5 text-[10px] font-bold bg-purple-500/10 border border-purple-500/30 text-purple-400 rounded-full">Unlimited</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-primary-accent transition-colors">Custom Engineering</h3>
            <p class="text-sm font-semibold text-secondary-silver/70 uppercase tracking-wide mb-4">The Performance Frontier</p>
            <p class="text-sm text-on-surface-variant/90 mb-6 leading-relaxed">
              <strong>Best For:</strong> Complex web applications, SaaS products, and enterprise platforms requiring sub-second load times and custom database structures.
            </p>
            <div class="border-t border-outline-ghost/30 pt-4 mb-8">
              <p class="text-xs font-semibold text-secondary-silver mb-2">Core Tech:</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Next.js & Astro</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">React & Tailwind v4</span>
                <span class="text-[11px] bg-surface-container-high px-2 py-1 rounded-sm text-on-surface">Edge Servers</span>
              </div>
            </div>
          </div>
          <a href="/services/nextjs-astro-web-apps" class="text-sm font-bold text-primary-accent group-hover:text-white transition-colors inline-flex items-center gap-1.5 focus:outline-none">
            Explore Custom Engineering <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

      </div>

    </div>
  </section>

  <!-- 5. UNIFIED SERVICE CATALOG SECTION -->
  <section class="py-24 md:py-32 bg-surface-container-lowest border-y border-outline-ghost/30" id="services">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8">
      
      <!-- Section Header -->
      <div class="mb-16 max-w-[800px]">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-6">
          Core Capabilities Across Your Stack
        </h2>
        <p class="text-base md:text-lg text-secondary-silver">
          We handle everything from visual UI/UX layout to edge-optimized infrastructure.
        </p>
      </div>

      <!-- Service Columns (Interactive Catalog Grid) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Category 1 -->
        <div class="p-8 border border-outline-ghost/40 bg-surface-container-low rounded-lg transition-all hover:bg-surface-container">
          <div class="w-12 h-12 bg-primary-maroon/20 border border-primary-accent/20 rounded-default flex items-center justify-center text-primary-accent mb-6 font-bold text-lg">01</div>
          <h3 class="text-xl font-bold text-white mb-6">Design & Platform Migration</h3>
          
          <div class="space-y-6">
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Figma-to-Platform Builds</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Pixel-perfect implementation into Shopify Liquid, custom Next.js/Astro frontend components, or fluid Wix Studio structures.
              </p>
            </div>
            <div class="h-[1px] bg-outline-ghost/20 w-full"></div>
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Monolith-to-Headless Transitions</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Decoupling bloated legacy sites into hybrid setups, using Next.js/Astro paired with Wix Headless, Headless Shopify, or headless WordPress backends.
              </p>
            </div>
          </div>
        </div>

        <!-- Category 2 -->
        <div class="p-8 border border-outline-ghost/40 bg-surface-container-low rounded-lg transition-all hover:bg-surface-container">
          <div class="w-12 h-12 bg-primary-maroon/20 border border-primary-accent/20 rounded-default flex items-center justify-center text-primary-accent mb-6 font-bold text-lg">02</div>
          <h3 class="text-xl font-bold text-white mb-6">Optimization, Speed & Auditing</h3>
          
          <div class="space-y-6">
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Core Web Vitals Engineering</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Debugging server-side response times, minifying asset delivery, and tuning LCP/INP metrics across all platforms.
              </p>
            </div>
            <div class="h-[1px] bg-outline-ghost/20 w-full"></div>
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Shopify Theme & App Audits</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Streamlining slow Shopify apps and converting outdated code to native Checkout Extensibility to maximize conversions.
              </p>
            </div>
          </div>
        </div>

        <!-- Category 3 -->
        <div class="p-8 border border-outline-ghost/40 bg-surface-container-low rounded-lg transition-all hover:bg-surface-container">
          <div class="w-12 h-12 bg-primary-maroon/20 border border-primary-accent/20 rounded-default flex items-center justify-center text-primary-accent mb-6 font-bold text-lg">03</div>
          <h3 class="text-xl font-bold text-white mb-6">Custom Extension & API Integrations</h3>
          
          <div class="space-y-6">
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Custom Plugins & Private Apps</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Writing secure PHP for WordPress or building dedicated apps for Shopify and custom backend platforms.
              </p>
            </div>
            <div class="h-[1px] bg-outline-ghost/20 w-full"></div>
            <div>
              <h4 class="text-sm font-bold text-secondary-silver mb-2">Omnichannel Synced Systems</h4>
              <p class="text-sm text-on-surface-variant/80 leading-relaxed">
                Connecting your web engine to external CRMs (HubSpot, Salesforce), ERP software, and global inventory managers.
              </p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- 6. PROCESS & WORKFLOW SECTION -->
  <section class="py-24 md:py-32 bg-surface">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8">
      
      <!-- Section Header -->
      <div class="text-center mb-20 max-w-[800px] mx-auto">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-6">
          How We Deliver
        </h2>
        <p class="text-base md:text-lg text-secondary-silver">
          A rigid grid process prioritizing functional alignment and clean edge configurations.
        </p>
      </div>

      <!-- The 4-Step Track (Timeline Layout) -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        
        <!-- Connector Line for Desktop -->
        <div class="hidden md:block absolute top-[28px] left-[50px] right-[50px] h-[1px] bg-outline-ghost/30 z-0"></div>

        <!-- Step 1 -->
        <div class="relative z-10 flex flex-col items-center md:items-start text-center md:text-left group">
          <div class="w-14 h-14 bg-surface border border-outline-ghost/50 rounded-full flex items-center justify-center mb-6 group-hover:border-primary-accent transition-all duration-300">
            <span class="text-primary-accent font-extrabold text-sm tracking-[0.1em]">01</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Tech Stack Alignment</h3>
          <p class="text-sm text-on-surface-variant/80 leading-relaxed">
            We analyze your functional requirements and select the specific platform tier that matches your scope and budget.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative z-10 flex flex-col items-center md:items-start text-center md:text-left group">
          <div class="w-14 h-14 bg-surface border border-outline-ghost/50 rounded-full flex items-center justify-center mb-6 group-hover:border-primary-accent transition-all duration-300">
            <span class="text-primary-accent font-extrabold text-sm tracking-[0.1em]">02</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Component System Design</h3>
          <p class="text-sm text-on-surface-variant/80 leading-relaxed">
            We design responsive layouts in Figma using adaptive tokens that translate perfectly to code or visual editors.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative z-10 flex flex-col items-center md:items-start text-center md:text-left group">
          <div class="w-14 h-14 bg-surface border border-outline-ghost/50 rounded-full flex items-center justify-center mb-6 group-hover:border-primary-accent transition-all duration-300">
            <span class="text-primary-accent font-extrabold text-sm tracking-[0.1em]">03</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Clean Engineering & Setup</h3>
          <p class="text-sm text-on-surface-variant/80 leading-relaxed">
            Our developers build your system using semantic principles, whether that means a native Shopify theme, a clean Astro build, or custom Wix Velo scripting.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="relative z-10 flex flex-col items-center md:items-start text-center md:text-left group">
          <div class="w-14 h-14 bg-surface border border-outline-ghost/50 rounded-full flex items-center justify-center mb-6 group-hover:border-primary-accent transition-all duration-300">
            <span class="text-primary-accent font-extrabold text-sm tracking-[0.1em]">04</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Launch & Optimization</h3>
          <p class="text-sm text-on-surface-variant/80 leading-relaxed">
            Rigorous stress testing, cross-device QA, accessibility compliance checks, and edge-cache configuration.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- 7. HIGH-INTENT CASE STUDIES (PORTFOLIO) -->
  <section class="py-24 md:py-32 bg-surface-container-lowest border-t border-outline-ghost/30" id="case-studies">
    <div class="max-w-[1280px] mx-auto px-4 md:px-8">
      
      <!-- Section Header -->
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white mb-6">
            Proven Performance Results
          </h2>
          <p class="text-base md:text-lg text-secondary-silver max-w-[600px]">
            We deploy production-grade experiences designed to convert, load instantly, and scale.
          </p>
        </div>
        <div>
          <a href="#contact" class="inline-flex items-center gap-1 text-sm font-bold text-primary-accent hover:text-white transition-colors focus:outline-none">
            Get Started on Your Scope <span class="hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>

      <!-- Case Studies Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Case 1 -->
        <div class="group bg-surface border border-outline-ghost rounded-lg overflow-hidden flex flex-col justify-between glow-card">
          <div>
            <div class="relative overflow-hidden aspect-[16/10] bg-surface-container-high border-b border-outline-ghost/30">
              <!-- Visual abstraction (isometric mesh styled mockup) -->
              <div class="absolute inset-0 bg-gradient-to-br from-primary-maroon/20 to-surface-container flex flex-col justify-center items-center p-6">
                <span class="text-7xl font-extrabold text-white/5 tracking-tighter absolute">SHOPIFY</span>
                <div class="text-center z-10">
