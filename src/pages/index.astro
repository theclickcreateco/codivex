<script>
  // Custom Selection Pills Handler
  const buttons = document.querySelectorAll('.choice-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();

      const type = btn.getAttribute('data-type');
      const val = btn.getAttribute('data-value');

      // Update hidden input
      const input = document.getElementById(`${type}-input`) as HTMLInputElement;
      if (input) input.value = val || '';

      // Reset siblings of same data-type
      document.querySelectorAll(`.choice-btn[data-type="${type}"]`).forEach(sibling => {
        sibling.classList.remove('bg-primary-maroon/20', 'border-primary-accent', 'text-white', 'shadow-[0_0_15px_rgba(255,179,181,0.15)]');
        sibling.classList.add('bg-surface-container-low', 'border-outline-ghost', 'text-secondary-silver');
      });

      // Highlight active button
      btn.classList.remove('bg-surface-container-low', 'border-outline-ghost', 'text-secondary-silver');
      btn.classList.add('bg-primary-maroon/20', 'border-primary-accent', 'text-white', 'shadow-[0_0_15px_rgba(255,179,181,0.15)]');
    });
  });

  // Form submit — Nodemailer API
  const form = document.getElementById('strategy-form') as HTMLFormElement | null;
  const successOverlay = document.getElementById('success-overlay');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  if (form && successOverlay) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Gather form data
      const formData = new FormData(form);
      const goalInput = document.getElementById('goal-input') as HTMLInputElement | null;
      const platformInput = document.getElementById('platform-input') as HTMLInputElement | null;
      if (goalInput) formData.set('goal', goalInput.value);
      if (platformInput) formData.set('platform', platformInput.value);

      // Loading state
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          // Show success overlay
          successOverlay.classList.remove('pointer-events-none', 'opacity-0');
          successOverlay.classList.add('opacity-100');
          form.reset();
          // Reset pills
          buttons.forEach(btn => {
            btn.classList.remove('bg-primary-maroon/20', 'border-primary-accent', 'text-white', 'shadow-[0_0_15px_rgba(255,179,181,0.15)]');
            btn.classList.add('bg-surface-container-low', 'border-outline-ghost', 'text-secondary-silver');
          });
        } else {
          console.error('Contact API error:', result);
          alert('Something went wrong. Please try messaging us on WhatsApp.');
        }
      } catch (err) {
        console.error('Submission error:', err);
        alert('Network error. Please try messaging us on WhatsApp.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Strategy Request';
        }
      }
    });
  }
</script>
